msgid "نصيحة: روح الجيم ودرّب الذكاء."
msgstr "Tip: Go to the gym and train Intelligence."

#: services/requirements.py:94
msgid "نصيحة: روح الجيم ودرّب القوة."
msgstr "Tip: Go to the gym and train Strength."

#: services/requirements.py:96
msgid "نصيحة: روح الجيم ودرّب الرشاقة."
msgstr "Tip: Go to the gym and train Agility."

#: services/requirements.py:99 templates/crimes.html:256
